{
  "name": "kadr",
  "version": "0.1.3",
  "description": "Kadr — GPU-accelerated multi-track video editor with AI integration",
  "main": "out/main/main.js",
  "author": "Black Triangle",
  "license": "GPL-3.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --win",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "mp4-muxer": "^5.1.5",
    "mp4box": "^2.3.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "ws": "^8.21.0"
  },
  "contributors": [
    "Claude (Anthropic)"
  ],
  "build": {
    "appId": "com.blacktriangle.kadr",
    "productName": "Kadr",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "electron/mcp-bridge.cjs",
      "scripts/transcribe.py",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**",
      "electron/mcp-bridge.cjs",
      "scripts/transcribe.py",
      "**/node_modules/@modelcontextprotocol/**",
      "**/node_modules/zod/**"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg"
      },
      {
        "from": "resources/python",
        "to": "python"
      }
    ],
    "win": {
      "target": [
        "zip",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
